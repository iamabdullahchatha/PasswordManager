# ─────────────────────────────────────────────────────────────────────────────
# SecureVault Pro — Backend Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Replace every CHANGE_ME value before running the app.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1
FRONTEND_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# Development: embedded-postgres is managed automatically by npm run dev:setup
# Production: supply your own PostgreSQL URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/securevault_pro

# ── JWT Secrets (generate fresh values — see commands below) ──────────────────
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_64_byte_hex_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_64_byte_hex_refresh_secret_different_from_access

# Token lifetimes  (e.g. 15m, 1h, 7d, 30d)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── AES-256-GCM Vault Encryption Key ─────────────────────────────────────────
# MUST be exactly 64 hex characters (= 32 bytes).
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_64_hex_chars_aes256_key
ENCRYPTION_IV_LENGTH=16

# ── Password Hashing ──────────────────────────────────────────────────────────
# 12 is secure; use 14 for extra hardening (slower login ~0.5s vs ~0.2s)
BCRYPT_ROUNDS=12

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Used to send password-reset links.
# Gmail tip: enable 2FA → create an "App Password" → use it as SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM="SecureVault Pro <noreply@securevault.pro>"

# Set to "true" to skip real emails and print the reset token to the console.
# ONLY for local development — always set to "false" in production.
EMAIL_DEV_MODE=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=logs/

# ── Auto-logout (frontend hint — milliseconds) ────────────────────────────────
INACTIVITY_TIMEOUT_MS=1800000
